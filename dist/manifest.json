{
  "manifest_version": 3,
  "name": "CleanIn - Hide LinkedIn promoted and suggested posts",
  "short_name": "CleanIn",
  "version": "1.1.0",
  "description": "Hide suggested, promoted, and promoted-by posts on LinkedIn home and feed.",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/",
    "https://www.linkedin.com/feed",
    "https://www.linkedin.com/feed/",
    "https://www.linkedin.com/feed/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/",
        "https://www.linkedin.com/feed",
        "https://www.linkedin.com/feed/",
        "https://www.linkedin.com/feed/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "CleanIn"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}
